-- Automation Engine Helpers
local d = {}
d.__index = d

d.Alive = function(target)
    if not target then return false end
    local humanoid = target:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

d.Pos = function(target, radius)
    local rootPart = GetRoot()
    if not rootPart or not target or not target:FindFirstChild("HumanoidRootPart") then return false end
    return (rootPart.Position - target.HumanoidRootPart.Position).Magnitude <= radius
end

d.Dist = function(target, radius)
    local rootPart = GetRoot()
    if not rootPart or not target or not target:FindFirstChild("HumanoidRootPart") then return false end
    return (rootPart.Position - target.HumanoidRootPart.Position).KeepZeroY().Magnitude <= radius
end

d.DistH = function(target, radius)
    local rootPart = GetRoot()
    if not rootPart or not target or not target:FindFirstChild("HumanoidRootPart") then return false end
    return (rootPart.Position - target.HumanoidRootPart.Position).Magnitude > radius
end

_G.MobHeight = _G.MobHeight or 30
_G.SaveData.BringMobs_Save = true
_G.BringRadius = 200
local bringOffset = 0

d.Kill = function(target, radius)
    if not (target and radius) then return end
    local enemyRoot = target:FindFirstChild("HumanoidRootPart")
    local enemyHumanoid = target:FindFirstChild("Humanoid")
    if not enemyRoot or not enemyHumanoid or enemyHumanoid.Health <= 0 then return end
    
    local rootPart = GetRoot()
    if not rootPart then return end
    
    if not target:GetAttribute("Locked") then
        target:SetAttribute("Locked", enemyRoot.CFrame)
    end
    
    local lockedCFrame = target:GetAttribute("Locked")
    PosMon = lockedCFrame.Position
    _B = true
    
    if _G.SaveData.BringMobs_Save then
        local cluster = {}
        for _, enemy in pairs(workspace.Enemies:GetChildren()) do
            local eRoot = enemy:FindFirstChild("HumanoidRootPart")
            local eHum = enemy:FindFirstChild("Humanoid")
            if enemy.Name == target.Name and eRoot and eHum and eHum.Health > 0 then
                if (eRoot.Position - rootPart.Position).Magnitude <= (_G.BringRadius or 200) then
                    table.insert(cluster, enemy)
                end
            end
        end
        
        bringOffset = bringOffset + 0.3
        local spacing = 10
        local totalMobs = #cluster
        for index, enemy in ipairs(cluster) do
            local eRoot = enemy.HumanoidRootPart
            local eHum = enemy.Humanoid
            eHum.WalkSpeed = 0
            eHum.JumpPower = 0
            eHum:ChangeState(11)
            eRoot.CanCollide = false
            eRoot.Size = Vector3.new(60, 60, 60)
            eRoot.Transparency = 1
            
            if index == 1 then
                eRoot.CFrame = lockedCFrame
            else
                local angle = ((index / totalMobs) * math.pi) * 2 + bringOffset
                local offsetVector = Vector3.new(math.cos(angle) * spacing, 0, math.sin(angle) * spacing)
                eRoot.CFrame = lockedCFrame + offsetVector
            end
        end
    end
    
    BringEnemy()
    EquipWeapon(_G.SelectWeapon)
    local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    _tp(lockedCFrame * CFrame.new(0, _G.MobHeight, 0))
end

