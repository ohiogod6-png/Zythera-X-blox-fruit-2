function SaveSettings()
    if not writefile then return false end
    local success = pcall(function()
        local encoded = Http:JSONEncode(_G.SaveData)
        writefile(SettingsPath, encoded)
    end)
    return success
end

function LoadSettings()
    if not (isfile and isfile(SettingsPath)) then return false end
    local success, result = pcall(function()
        local content = readfile(SettingsPath)
        return Http:JSONDecode(content)
    end)
    if success and result then
        _G.SaveData = result
        return true
    end
    return false
end

function GetSetting(key, default)
    return _G.SaveData[key] ~= nil and _G.SaveData[key] or default
end

