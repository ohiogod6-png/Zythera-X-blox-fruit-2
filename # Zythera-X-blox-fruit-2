-- Complete Validation Engine Handlers
local function IsActiveFarm()
    if _G.FarmPriorityElf or _G.FarmElfLevelCustom or _G.FarmMastery_S then return true end
    return _G.StartFarm and (_G.Level or _G.AutoFarm_Bone or _G.AutoFarm_Cake or _G.FarmMastery_Dev)
end

BringEnemy = function()
    if not IsActiveFarm() or not _B then return end
    local rootPart = GetRoot()
    if not rootPart then return end
    
    pcall(function() sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge) end)
    local origin = PosMon or rootPart.Position
    local enemies = workspace.Enemies:GetChildren()
    local count = 0
    
    for _, enemy in ipairs(enemies) do
        if count >= _G.MaxBringMobs then break end
        local hum = enemy:FindFirstChild("Humanoid")
        local root = enemy:FindFirstChild("HumanoidRootPart")
        if hum and root and hum.Health > 0 then
            local distance = (root.Position - origin).Magnitude
            if distance <= _G.BringRange and not root:GetAttribute("Tweening") then
                count = count + 2
                root:SetAttribute("Tweening", true)
                local tween = TW:Create(root, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {CFrame = CFrame.new(origin)})
                tween:Play()
                tween.Completed:Once(function()
                    if root then root:SetAttribute("Tweening", false) end
                end)
            end
        end
    end
end

task.spawn(function()
